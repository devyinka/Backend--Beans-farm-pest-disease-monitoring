# Backend environment template
# Copy this file to .env and fill in real values.

# Frontend URL allowed for CORS and Socket.IO
FRONTEND_URL="http://localhost:3000"

# Optional ESP32/browser origin if your device or custom client sends an Origin header
ESP32_ORIGIN="http://192.168.1.50"

# Optional comma-separated list of extra allowed origins
CORS_ALLOWED_ORIGINS="http://192.168.1.60,http://localhost:5173"

# Backend API port
PORT=5001

# Environment mode: development | production | test
NODE_ENV="development"

# JWT configuration
JWT_SECRET="replace-with-a-very-strong-secret"
JWT_EXPIRES_IN="7d"

# MongoDB behavior
# Set to "true" in production to fail startup if DB connection fails.
MONGODB_REQUIRED="false"

# MongoDB connection string
# Example:
# MONGODB_URI="mongodb://127.0.0.1:27017/myapp"
MONGODB_URI="replace-with-your-mongodb-connection-string"
